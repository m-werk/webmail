{
    "name": "webmail/contao-webmail",
    "description": "Verwaltung von E-Mail-Aussendungen",
    "keywords": [
        "contao",
        "bundle",
        "tag 3",
        "tag 4"
    ],
    "type": "contao-bundle",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Andreas Steinkellner",
            "email": "andreas.steinkellner@privatconsult.com",
            "homepage": "https://github.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/webmail/contao-webmail/issues",
        "source": "https://github.com/webmail/contao-webmail"
    },
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^4.13 || ^5.0"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "Webmail\\ContaoWebmail\\": "src/"
        },
		"classmap": [
			"contao/"
		],
		"exclude-from-classmap": [
			"contao/config/",
			"contao/dca/",
			"contao/languages/",
			"contao/templates/"
		]
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": false,
            "contao/manager-plugin": false,
            "contao-community-alliance/composer-plugin": true
        }
    },
    "extra": {
        "contao-manager-plugin": "Webmail\\ContaoWebmail\\ContaoManager\\Plugin"
    },
    "scripts": {
        "cs-fixer": "@php tools/ecs/vendor/bin/ecs check config/ contao/ src/ templates/ tests/ --config tools/ecs/config.php --fix --ansi",
        "unit-tests": "@php tools/phpunit/vendor/bin/phpunit -c tools/phpunit/phpunit.xml.dist"
    },
    "version": "1.0"
}